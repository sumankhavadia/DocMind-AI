# Frontend Environment Variables

# API Base URL (backend URL)
# Development: Uses Vite proxy to localhost:5000, so this is optional
# Production: Must point to your deployed backend (e.g., https://your-backend.onrender.com/api)
VITE_API_URL=

# Example for production:
# VITE_API_URL=https://docmind-backend.onrender.com/api
